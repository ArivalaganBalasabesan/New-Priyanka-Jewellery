# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/jewelry_shop

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Metal Rate API (Replace with your actual API key)
METAL_API_KEY=your_metal_api_key
METAL_API_URL=https://metals-api.com/api/latest

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Admin Seed Credentials
ADMIN_EMAIL=admin@priyankajewellery.com
ADMIN_PASSWORD=Admin@123456
